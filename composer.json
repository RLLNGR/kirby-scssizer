{
    "name": "rllngr/kirby-scssizer",
    "description": "Kirby plugin — SCSS compiler powered by scssphp, no Node.js or Ruby required",
    "keywords": ["kirby", "kirby-plugin", "scss", "sass", "css", "compiler"],
    "type": "kirby-plugin",
    "license": "MIT",
    "homepage": "https://github.com/RLLNGR/kirby-scssizer",
    "authors": [
        {
            "name": "Nicolas Rollinger",
            "email": "contact@rollinger.design",
            "homepage": "https://rollinger.design",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/RLLNGR/kirby-scssizer",
        "issues": "https://github.com/RLLNGR/kirby-scssizer/issues"
    },
    "require": {
        "php": ">=8.1",
        "getkirby/composer-installer": "^1.0",
        "scssphp/scssphp": "^1.12"
    },
    "autoload": {
        "psr-4": {
            "Rllngr\\SCSSizer\\": "classes/"
        }
    },
    "extra": {
        "installer-name": "kirby-scssizer"
    }
}
